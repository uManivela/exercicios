# Função para mostrar game over
def mostrar_game_over():
    global jogo_ativo
    jogo_ativo = False
    
    tela_mensagem.clear()

    # Efeito visual de game over
    tela.bgcolor('dark red')
    tela.update()
    tela.sleep(0.1)
    tela.bgcolor('black')
    tela.update()
    tela.sleep(0.1)
    tela.bgcolor('dark red')
    tela.update()
    tela.sleep(0.1)
    tela.bgcolor('black')

    tela_mensagem.goto(0, 100)
    tela_mensagem.color('red')
    tela_mensagem.write('   GAME OVER   ', align='center', font=('Courier', 32, 'bold'))

    tela_mensagem.goto(0, 40)
    tela_mensagem.color('white')
    tela_mensagem.write(f'Pontuação Final: {pontos}', align='center', font=('Courier', 20, 'normal'))

    tela_mensagem.goto(0, 0)
    tela_mensagem.color('yellow')
    tela_mensagem.write(f'Recorde: {recorde}', align='center', font=('Courier', 18, 'normal'))

    if pontos >= recorde and pontos > 0:
        tela_mensagem.goto(0, -40)
        tela_mensagem.color('gold')
        tela_mensagem.write('   NOVO RECORDE!   ', align='center', font=('Courier', 20, 'bold'))

    tela_mensagem.goto(0, -100)
    tela_mensagem.color('cyan')
    tela_mensagem.write('Pressione ESPAÇO para jogar novamente', align='center', font=('Courier', 14, 'normal'))

    tela_mensagem.goto(0, -130)
    tela_mensagem.color('white')
    tela_mensagem.write('Pressione M para o Menu Principal', align='center', font=('Courier', 14, 'normal'))

    tela.update()

# Função para iniciar o jogo
def iniciar_jogo(dificuldade):
    global pontos, velocidade_jogo, jogo_ativo, jogo_pausado, dificuldade_atual
    global comida_especial_ativa, comida_especial_tempo

    dificuldade_atual = dificuldade
    velocidade_jogo = DIFICULDADES[dificuldade]['velocidade']

    tocar_som('inicio')

    #Limpar tela de inicio
    tela_mensagem.clear()

    # Configurar cor de fundo
    tela.bgcolor(DIFICULDADES[dificuldade]['cor_fundo'])

    # Restar varáveis
    pontos = 0
    jogo_pausado = False
    jogo_ativo = True
    comida_especial_ativa = False
    comida_especial_tempo = 0

    # Resetar cobrinha
    cabeca.goto(0,0)
    cabeca.direction = 'stop'
    cabeca.showturtle()

    # Limpar segmentos
    for segmentos in segmentos:
        segmentos.hideturtle()
    segmentos.clear()

    # Resetar comida
    comida.goto(0, 100)
    comida.showturtle()

    # Esconder comida especial
    comida_especial.goto(1000, 1000)
    comida_especial.hideturtle()

    # Atualizar displays
    atualizar_placar()
    atualizar_info()
    
    tela.update()

# Funções para selecionar dificuldade
def selecionar_facil():
    if not jogo_ativo:
        iniciar_jogo('1')

def selecionar_medio():
    if not jogo_ativo:
        iniciar_jogo('2')

def selecionar_dificil():
    if not jogo_ativo:
        iniciar_jogo('3')

def selecionar_impossivel():
    if not jogo_ativo:
        iniciar_jogo('4')

def jogar_novamente():
    if not jogo_ativo:
        iniciar_jogo(dificuldade_atual)

def voltar_menu():
    mostrar_tela_inicio()

# Funções de controle da Cobrinha
def ir_cima():
    if jogo_ativo and not jogo_pausado and cabeca.direction != 'down':
        cabeca.direction = 'up'

def ir_baixo():
    if jogo_ativo and not jogo_pausado and cabeca.direction != 'up':
        cabeca.direction = 'down'

def ir_esquerda():
    if jogo_ativo and not jogo_pausado and cabeca.direction != 'right':
        cabeca.direction = 'left'

def ir_direita():
    if jogo_ativo and not jogo_pausado and cabeca.direction != 'left':
        cabeca.direction = 'right'

# Função para pausar o jogo
def pausar_jogo():
    global jogo_pausado
    if jogo_ativo:
        jogo_pausado = not jogo_pausado
        if jogo_pausado:
            tela_mensagem.goto(0,0)
            tela_mensagem.color('yellow')
            tela_mensagem.write('   PAUSADO    ', align='center', font=('Courier' , 30, 'bold'))
        else:
            tela_mensagem.clear()

# Função para reiniciar o jogo
def reiniciar_jogo():
    if jogo_ativo:
        iniciar_jogo(dificuldade_atual)

# Função para sair do jogo
def sair_jogo():
    salvar_recorde()
    tela.bye()

# Função de Movimento da Cobrinha
def mover ():
    if cabeca.direction == 'up':
        y = cabeca.ycor()
        cabeca.sety(y + 20)
