# Arquivo para salvar o recorde
ARQUIVO_RECORDE = "recorde.txt"

# Configurações da Dificuldade
DIFICULDADES = {
    '1': {'nome': 'Fácil', 'velocidade': 0.15, 'cor_fundo': 'dark green'},
    '2': {'nome': 'Médio', 'velocidade': 0.1, 'cor_fundo': 'dark blue'},
    '3': {'nome': 'Difícil', 'velocidade': 0.06, 'cor_fundo': 'dark red'},
    '4': {'nome': 'Impossível', 'velocidade': 0.03, 'cor_fundo': 'black'}
}

# Variáveis Globais
pontos = 0
recorde = 0
velocidade_jogo = 0.1
jogo_pausado = False
jogo_ativo = False
dificuldade_atual = '2'

# Função para carregar o recorde do arquivo
def carregar_recorde():
    global recorde
    try:
        if os.path.exists(ARQUIVO_RECORDE):
            with open(ARQUIVO_RECORDE, 'r') as arquivo:
                recorde = int(arquivo.read().strip())
    except:
        recorde = 0

# Função para salvar o recorde no arquivo
def salvar_recorde():
    global recorde
    try:
        with open(ARQUIVO_RECORDE, 'w') as arquivo:
            arquivo.write(str(recorde))
    except:
        pass

# Função para trocar som
def tocar_som(tipo):
    if not SOM_DISPONIVEL:
        return
    try:
        if tipo == 'comer':
            winsound.Beep(800,100) # Som agudo curto
        elif tipo == 'colisao':
            winsound.Beep(200, 300) # Som grave longo
        elif tipo == 'recorde':
            # Melodia de Vitória
            winsound.Beep(523, 100)  # Dó
            winsound.Beep(659, 100)  # Mi
            winsound.Beep(784, 100)  # Sol
            winsound.Beep(1047, 200) # Dó alto
        elif tipo == 'inicio':
            winsound.Beep(440, 150)
            winsound.Beep(550, 150)
            winsound.Beep(660, 200)
    except:
        pass

# Carregar recorde ao iniciar
carregar_recorde()

