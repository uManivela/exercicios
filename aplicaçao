#Simulador de aplicação financeira com lucro real

# Dados iniciais 
valor_inicial = 10000.00 #R$
taxa_juros_mensal = 0.01 #1% ao mês
inflacao_mensal = 0.004  #0.4% ao mês
meses = 6

# Cálculo do valor final nominal
valor_final = valor_inicial * (1 + taxa_juros_mensal) ** meses

# Lucro nominal
lucro_nominal = valor_final - valor_inicial

# Ajuste pela inflação (valor real)
fator_inflacao = (1 + inflacao_mensal) ** meses
valor_real = valor_final / fator_inflacao

# Lucro real
lucro_real = valor_real - valor_inicial

# Exibição dos resultados
print('=' * 40)
print('SIMULAÇÃO DE APLICAÇÃO FINANCEIRA')
print('=' * 40)
print(f'valor aplicado: R$ {valor_inicial:.2f}')
print(f'Prazo: {meses} meses')
print(f'Rendimento: {taxa_juros_mensal * 100:.2f}% ao mês')
print(f'Inflação: {inflacao_mensal * 100:.2f}% ao mês')
print('-' * 40)
print(f'Valor final nominal: R$ {valor_final:.2f}')
print(f'Lucro nominal: R$ {lucro_nominal:.2f}')
print(f'Valor final real: R$ {valor_real:.2f}')
print(f'Lucro real: R$ {lucro_real:.2f}')
print('=' * 40)
