# ==============================
# CONFIGURAÇÃO DO APP
# ==============================

st.set_page_config(page_title='Simulador de Investimentos', layout='wide')

st.title('Simulador de Investimentos Inteligente')
st.write('Simulação de carteira com ações, ouro, dólar e renda fixa (dados reais).')

# ==============================
# TICKERS (MERCADO GLOBAL)
# ==============================

TICKERS = {
    "Ações (S&P500)": 'SPY',
