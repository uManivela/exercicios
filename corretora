# =============================
# INPUTS
# =============================

col1,col2, col3 = st.columns(3)

with col1:
    inicial = st.number_input('Valor inicial (R$)', value=10000)

with col2:
    aporte = st.number_input('Aporte mensal (R$)', value=1000)

with col3:
    anos = st.number_input('Anos', value=10)

perfil_nome = st.selectbox('Perfil do investidor', list(PERFIS.keys()))

rodar = st.button('Rodar simulação')

# ================================
# DADOS REAIS
# ================================

@st.cache_data
def baixar_dados():
    dados = {}
    for nome, ticker in TICKERS.items():
        df = yf.download(ticker, period='10y', interval='1mo', progress=False)["Close"]
        dados[ticker] = df.pct_change()  # Usar ticker como chave

    
    df_completo = pd.concat(dados, axis=1).dropna()
    df_completo.columns = list(dados.keys())
    return df_completo

