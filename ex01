# ====================================================
# PROGRAMAÇÃO EM PYTHON PARA INCIANTES
#=====================================================

# Este programa mostra conceitos básicos da programação.
# Ele usa mensagens na tela, entrada de dados e decisões.

print("================================================")
print("     APRENDENDO PROGRAMAÇÃO COM PYTHON           ")
print("================================================")

# A programação serve para criar instruções para o computador.
print ("Programar é escrever instruções para o computador.")

# O print() mostra mensagens na tela.
print("Vamos aprende passo a passo")

# input() permite que o usuário digite algo.
nome = input("Digite seu nome:  ")

# Guardamos o valor digitado em uma variável chamada nome.
print("Olá,", nome)

# Variáveis armazenam informações.
idade = input("Digite sua idade: ")

# O programa continua mostrando informações.
print("Você tem", idade, "anos.")

# Programação também envolve decisões.
# O if verifica uma condição.
if idade >= "18":
    print("Você já é maior de idade.")
if idade < "18":
    print('Você ainda é menor de idade.')

# Comentários ajudam a explicar o código.
# Eles não são executados pelo Python.

print("Vamos continuar com mais exemplos.")

# Podemos pedir mais informações ao usuário.
cidade = input("Digite sua cidade: ")
print("Cidade informada:", cidade)

# Outra variável simples.
curso = input("Qual curso você está estudando ?")
print("Curso escolhido:", curso)
# O computador segue as instruções em ordem.
print("A programação é lógica e organizada.")

# Podemos explicar que cada linha tem um papel.
print("Cada comando faz uma parte do trabalho.")

# Mais um exemplo de decisão.
resposta = input("VocÊ gosta de aprender programção (sim/não)")

if resposta == "sim":
    print("Que ótimo! Continue praticando")
if resposta == "não":
    print("Tudo bem! Você pode aprender aos poucos.")

# A programação também ajuda em jogos, slides e aplciativos.
print("Python é usado em muitos projetos.")

# Criamos variáveis com dados do usuário.
sobrenome = input("Digite seu sobrenome: ")
print("Seu nome completo é:", nome, sobrenome)

# O computador pode repetir mensagens.
print("Estudar todos os dias ajuda muito.")

# Podemos comparar respostas.
cor = input("Qual a sua cor favorita? ")
print("Sua cor favorita é:", cor)

# Mais um exemplo simples da explicação.
print("Programar exige prática e atenção.")

# if é uma estrutura de decisão.
pergunta = input('Você quer aprender mais ? (sim/não): ')

if pergunta == "sim":
    print("Excelente! Aprender é um processo contínuo.")
if pergunta == "não":
    print("Sem problema, você pode voltar depois.")

# Podemos organizar o código com mensagens claras.
print("Agora vamos ver um pequeno resumo.")

# Mostrando dados coletados.
print("Nome:", nome)
print("Sobrenome:", sobrenome)
print("Idade:", idade)
print("Cidade:", cidade)
print("Curso:", curso)
print("Cor favorita:", cor)

# Programar é resolver problemas com lógica.
print("A lógica é muito importante na programação. ")

# Python é uma linguagem de programação fácil pra iniciantes.
print("Python é uma ótima linguagem pra começar. ")

# O usuário interage com o programa.
print("Você participou do programa corretamente. ")

# Última pergunta.
final = input("Quer continuar estudando Python ? (sim/não)")

if final == "sim":
    print("Parabéns! Continue praticando todos os dias. ")
if final == "não":
    print("Tudo bem! O importante é não desistir.")

# Encerramento do programa.
print("=======================================================")
print("                 FIM DO PROGRAMA                       ")
print("=======================================================")
print("Obrigado por aprender programação com Python")
