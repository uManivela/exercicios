#Exemplo de código para avaliar o risco de saúde usando uma árvore de decisão

from sklearn.tree import DecisionTreeClassifier
import sklearn.tree

# Ddaos de exemplo
x = [
    [25, 120], # idade pressão
    [60, 180],
    [35, 130],
    [70, 190]
]

y = [0, 1, 0, 1] # 0=baixo risco, 1=alto risco

modelo = DecisionTreeClassifier()
modelo.fit(x,y)

novo_paciente = [[65, 175]]

risco = modelo.predict(novo_paciente)

print('Alto risco' if risco[0] else 'Baixo risco')
