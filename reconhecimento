import face_recognition
import cv2
import os
import numpy as np

# Pasta onde estão as imagens cadastradas
CAMINHO_BANCO = os.path.join(os.path.dirname(__file__), "Banco")

rostos_conhecidos = []
nomes = []

if not os.path.isdir(CAMINHO_BANCO):
    print(f'A pasta "{CAMINHO_BANCO}" não foi encontrada.')
    raise SystemExit(1)

# Carrega as imagens do banco
for arquivo in os.listdir(CAMINHO_BANCO):
    caminho = os.path.join(CAMINHO_BANCO, arquivo)

    if not os.path.isfile(caminho):
        continue

    imagem = face_recognition.load_image_file(caminho)
    codificacoes = face_recognition.face_encodings(imagem)

    if len(codificacoes) > 0:
        rostos_conhecidos.append(codificacoes[0])
        nomes.append(os.path.splitext(arquivo)[0])
    
if len(rostos_conhecidos) == 0:
    print(f'Nenhum rosto válido foi encontrado em "{CAMINHO_BANCO}"')
    raise SystemExit(1)

print('Banco carregado.')

# Webcam
camera = cv2.VideoCapture(0)

if not camera.isOpened():
    print('Não foi possível acessar a webcam.')
    raise  SystemExit(1)

while True:
    ret, frame = camera.read()

    if not ret:
        print("Falha ao ler imagem da webcam.")
        break

    rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)

    locais = face_recognition.face_locations(rgb)
    codigos = face_recognition.face_encodings(rgb, locais)

    for (top, right, bottom, left), codigo in zip(locais, codigos):

        resultados = face_recognition.compare_faces(
            rostos_conhecidos,
            codigo,
            tolerance=0.5
        )

        nome = "Desconhecido"

        distancias = face_recognition.face_distance(
            rostos_conhecidos,
            codigo
        )

        if len(distancias) > 0:
            indice = np.argmin(distancias)

            if resultados[indice]:
                nome = nomes[indice]

        cv2.rectangle(frame, (left, top), (right, bottom), (0,255,0), 2)
        cv2.putText(
            frame,
            nome,
            (left, top - 10),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.8,
            (0,255,0),
            2
        )

    cv2.imshow('Biometria Facial', frame)

    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

camera.release()
cv2.destroyAllWindows()
